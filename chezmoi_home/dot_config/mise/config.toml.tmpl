# ~/.config/mise/config.toml
# Managed by chezmoi - DO NOT EDIT MANUALLY
# Source: ~/.local/share/chezmoi/chezmoi_home/dot_config/mise/config.toml.tmpl

[tools]
# Programming languages
"python" = "latest"
"node" = "lts"

# Language servers for Neovim
"lua-language-server" = "latest"
"github:Feel-ix-343/markdown-oxide" = "latest"
"npm:@github/copilot-language-server" = "latest"

"tree-sitter" = "latest"

# CLI tools (cross-platform, managed by mise instead of system package managers)
"npm:@github/copilot" = "latest"
"ripgrep" = "latest"
"fd" = "latest"
"bat" = "latest"
"fzf" = "latest"
"lazygit" = "latest"
"zoxide" = "latest"
"starship" = "latest"
"yazi" = "latest"
"github:Canop/broot" = "latest"
"ast-grep" = "latest"
"difftastic" = "latest"
"npm:httpyac" = "latest"
"resvg" = "latest"
{{ if not .isWorkDevBox }}
"zola" = "latest"
{{ end }}

# .NET development tools
[tools."dotnet:roslyn-language-server"]
version = "latest"
prerelease = true

{{ if eq .chezmoi.os "windows" }}
# Debuggers (Windows only)
[tools."github:Samsung/netcoredbg"]
version = "latest"
version_prefix = ""
bin_path = "netcoredbg"
asset_pattern = "netcoredbg-win64.zip"
{{ end }}

[settings]
# Enable experimental features
experimental = true

# Shorten status output for cleaner shell prompts
[settings.status]
missing_tools = "never"
show_env = false
show_tools = false
