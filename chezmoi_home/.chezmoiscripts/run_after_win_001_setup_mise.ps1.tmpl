{{ if eq .chezmoi.os "windows" }}

{{ template "ps1/bootstrap-common.ps1" . }}

Write-Header "Setting up mise tools"

# Verify mise is installed
if (-not (Get-Command mise -ErrorAction SilentlyContinue)) {
    Write-Error "mise is not installed or not in PATH"
    Write-Host "Please install mise first: https://mise.jdx.dev/getting-started.html" -ForegroundColor Red
    exit 1
}

Write-Host "mise version: $(mise --version)" -ForegroundColor Cyan

# Ensure mise-shim.exe exists next to mise.exe (winget package doesn't include it)
$miseExe = (Get-Command mise -CommandType Application -ErrorAction SilentlyContinue).Source
if ($miseExe) {
    # Resolve symlink (e.g. WinGet\Links\mise.exe -> actual path)
    $link = Get-Item $miseExe
    if ($link.Target) { $miseExe = $link.Target }
    $miseDir = Split-Path $miseExe
    $shimPath = Join-Path $miseDir "mise-shim.exe"
    if (-not (Test-Path $shimPath)) {
        Write-Host "Copying mise-shim.exe next to mise.exe..." -ForegroundColor Cyan
        Copy-Item $miseExe $shimPath -ErrorAction SilentlyContinue
        if (Test-Path $shimPath) {
            Write-Host "[OK] mise-shim.exe created" -ForegroundColor Green
        } else {
            Write-Warning "Could not copy mise-shim.exe (may need admin privileges)"
        }
    }
}

# Add neovim plugin (required for neovim support)
mise plugins add neovim

# Install all tools declared in ~/.config/mise/config.toml
mise install

Write-Header "mise setup complete!"
Write-Host "Installed tools:"
mise list

{{ end }}
